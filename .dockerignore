# Virtual environment / package manager
.venv/
__pycache__/
*.py[cod]

# Git
.git/
.gitignore

# Secrets (mounted at runtime, never baked into the image)
.env

# Runtime data (volume-mounted, not part of the image)
jobs.db
*.db
data/

# Tests (not needed at runtime)
tests/
.pytest_cache/

# Linting / type-checking caches
.mypy_cache/
.ruff_cache/

# Build artifacts
dist/
*.egg-info/

# Misc
files.zip
README.md
.DS_Store
